# Hivemind Configuration Example

qdrant:
  url: "http://localhost:6333"
  # api_key: "your-qdrant-api-key"
  collection_name: "hivemind_code"

model:
  api_url: "http://localhost:1234/v1"
  model_name: "qwen3-4B-embedding"
  # api_key: "your-api-key"
  embedding_dim: 2500

chat:
  api_url: "http://localhost:1234/v1"
  model_name: "gpt-4o"
  # api_key: "your-api-key"

chunking:
  strategy: "by_size"
  language_aware: true
  by_size:
    chunk_size: 500
    overlap: 50
  by_lines:
    chunk_lines: 50
    overlap_lines: 5
  ast:
    chunk_lines: 50
    overlap_lines: 5

scout:
  urls:
    - "https://docs.crawl4ai.com"
    - "https://qdrant.tech/documentation"
  output_directory: "docs/scout"
  recursive: false
  content_filter: true
  max_pages_per_domain: 50
  # Search backend configuration (duckduckgo, brave, searxng)
  search_backend: "duckduckgo"
  # searxng_url: "http://localhost:8888"
  # searxng_categories:
  #   - general
  #   - it
  #   - science

api:
  host: "0.0.0.0"
  port: 8001

logging:
  level: "INFO"
  # file_path: "hivemind.log"

git_enabled: true
git_only_tracked: false

# Sparse vector configuration (for hybrid search)
# sparse:
#   enabled: true
#   vocab_size: 50000
